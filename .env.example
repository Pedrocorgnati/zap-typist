# ============================================
# ZAP TYPIST — ARQUIVO DE AMBIENTE (EXEMPLO)
# ============================================
# Copie este arquivo para .env e preencha os valores
# Este arquivo é versionado; .env é ignorado pelo git

# ────────────────────────────────────────────
# APLICAÇÃO
# ────────────────────────────────────────────
# Nível de log: DEBUG, INFO, WARNING, ERROR
ZAP_TYPIST_LOG_LEVEL=INFO

# Ativa modo desenvolvedor
ZAP_TYPIST_DEV_MODE=false

# Ativa logs detalhados
DEBUG=false

# ────────────────────────────────────────────
# DATA E CACHE
# ────────────────────────────────────────────
# Caminho alternativo para dados (opcional)
ZAP_TYPIST_DATA_DIR=

# ────────────────────────────────────────────
# NAVEGADOR
# ────────────────────────────────────────────
# Caminho para Chrome/Chromium (opcional, auto-detecta se vazio)
ZAP_TYPIST_CHROME_BIN=

# ────────────────────────────────────────────
# BANCO DE DADOS
# ────────────────────────────────────────────
# SQLite connection string
DATABASE_URL=sqlite:///./zap_typist.db
