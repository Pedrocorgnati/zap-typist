# Caminho absoluto opcional para sobrepor APP_DATA_DIR. Se vazio, usa ~/.local/share/zap-typist.
ZAP_TYPIST_DATA_DIR=

# Nível de log: DEBUG, INFO, WARNING, ERROR. Default: INFO
ZAP_TYPIST_LOG_LEVEL=

# Habilitar modo desenvolvedor (mostra extra debug na barra de status). Default: false
ZAP_TYPIST_DEV_MODE=

# Caminho do binário Chrome (usado pelo Rock 3). Se vazio, autodetecta via `which google-chrome`.
ZAP_TYPIST_CHROME_BIN=
